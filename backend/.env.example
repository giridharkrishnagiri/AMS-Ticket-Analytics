APP_NAME=AMS Ticket Intelligence
APP_VERSION=0.1.0
ENVIRONMENT=local
DATABASE_URL=postgresql+psycopg://<user>:<password>@localhost:5432/ams_ticket_intelligence
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3025,http://127.0.0.1:3025
LOCAL_STORAGE_ROOT=./storage

# Optional GenAI provider keys. Do not store these in the database.
# OPENAI_API_KEY=
# AZURE_OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# LITELLM_API_KEY=

# Optional GenAI model override for high-volume ticket classification enrichment.
# When blank, the backend uses the model configured in the GenAI settings table.
GENAI_TICKET_CLASSIFICATION_BUTTON_ENABLED=false
GENAI_TICKET_CLASSIFICATION_MODEL_NAME=gpt-4.1-mini
# Larger batches need enough response tokens to return complete JSON.
GENAI_TICKET_CLASSIFICATION_MAX_OUTPUT_TOKENS=4000

# Cluster-based ticket categorization. This is the preferred high-volume mode.
GENAI_TICKET_CLUSTER_ANALYSIS_BUTTON_ENABLED=true
GENAI_TICKET_CLUSTER_EMBEDDING_MODEL_NAME=text-embedding-3-small
GENAI_TICKET_CLUSTER_LABEL_MODEL_NAME=gpt-4.1-mini
GENAI_TICKET_CLUSTER_LABEL_MAX_OUTPUT_TOKENS=4000
GENAI_TICKET_CLUSTER_EMBEDDING_BATCH_SIZE=100
GENAI_TICKET_CLUSTER_LABEL_BATCH_SIZE=15
# Adaptive mode runs recursive KMeans and uses the per-level modes below.
# Use fixed mode only to reproduce the old exact-count KMeans behavior.
GENAI_TICKET_CLUSTER_MODE=adaptive
# Per-level modes for adaptive clustering:
# capped = split by distance until the configured count cap is reached.
# threshold_only = split by distance only; the configured count is informational.
# The aliases adaptive=capped and fixed=threshold_only are also accepted per level.
GENAI_TICKET_CLUSTER_LEVEL_1_MODE=capped
GENAI_TICKET_CLUSTER_LEVEL_2_MODE=capped
GENAI_TICKET_CLUSTER_LEVEL_3_MODE=threshold_only
GENAI_TICKET_CLUSTER_LEVEL_1_COUNT=20
GENAI_TICKET_CLUSTER_LEVEL_2_COUNT=200
GENAI_TICKET_CLUSTER_LEVEL_3_COUNT=600
# Cosine distance thresholds from cluster centroid. Lower values create more clusters.
GENAI_TICKET_CLUSTER_LEVEL_1_DISTANCE_THRESHOLD=0.30
GENAI_TICKET_CLUSTER_LEVEL_2_DISTANCE_THRESHOLD=0.20
GENAI_TICKET_CLUSTER_LEVEL_3_DISTANCE_THRESHOLD=0.10
# Clusters below this ticket count are assigned rare labels and skipped for LLM naming.
GENAI_TICKET_CLUSTER_MIN_LLM_LABEL_TICKET_COUNT=3
GENAI_TICKET_CLUSTER_REPRESENTATIVE_TICKET_COUNT=8

# Cluster-level automation opportunity analysis.
GENAI_TICKET_AUTOMATION_ANALYSIS_BUTTON_ENABLED=true
GENAI_TICKET_AUTOMATION_MODEL_NAME=gpt-4.1-mini
GENAI_TICKET_AUTOMATION_MAX_OUTPUT_TOKENS=4000
GENAI_TICKET_AUTOMATION_REPRESENTATIVE_TICKET_COUNT=12
GENAI_TICKET_AUTOMATION_CLUSTERS_PER_REQUEST=10

# Optional outbound HTTPS settings for corporate proxy / SSL inspection environments.
# The backend also tries the Windows/system certificate store automatically via truststore.
# Set these only if your environment still needs an explicit certificate bundle or proxy.
# SSL_CERT_FILE=C:\path\to\corporate-ca-bundle.pem
# SSL_CERT_DIR=C:\path\to\corporate-ca-directory
# HTTPS_PROXY=http://proxy.example.com:8080
# HTTP_PROXY=http://proxy.example.com:8080
# NO_PROXY=127.0.0.1,localhost
