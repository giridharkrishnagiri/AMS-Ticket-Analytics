APP_NAME=AMS Ticket Intelligence
APP_VERSION=0.1.0
ENVIRONMENT=local
DATABASE_URL=postgresql+psycopg://<user>:<password>@localhost:5432/ams_ticket_intelligence
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3025,http://127.0.0.1:3025
LOCAL_STORAGE_ROOT=./storage

# Optional GenAI provider keys. Do not store these in the database.
# OPENAI_API_KEY=
# AZURE_OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# LITELLM_API_KEY=

# Optional outbound HTTPS settings for corporate proxy / SSL inspection environments.
# SSL_CERT_FILE=C:\path\to\corporate-ca-bundle.pem
# SSL_CERT_DIR=C:\path\to\corporate-ca-directory
# HTTPS_PROXY=http://proxy.example.com:8080
# HTTP_PROXY=http://proxy.example.com:8080
# NO_PROXY=127.0.0.1,localhost
